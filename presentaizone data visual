```{r}
#| label: init
#| include: false

options(repos = c(CRAN = "https://cloud.r-project.org"))

pkgs <- c("tidytuesdayR", "tidyverse", "scales",
          "knitr", "broom", "sf", "tigris", "ggrepel")

missing_pkgs <- pkgs[!vapply(pkgs, requireNamespace,
                             logical(1), quietly = TRUE)]
if (length(missing_pkgs)) install.packages(missing_pkgs, dependencies = TRUE)

invisible(lapply(pkgs, library, character.only = TRUE))
options(tigris_use_cache = TRUE)

theme_pres <- function(base_size = 11) {
  theme_minimal(base_size = base_size) %+replace%
    theme(
      plot.title    = element_text(face = "bold", size = base_size + 2,
                                   margin = margin(b = 4)),
      plot.subtitle = element_text(color = "grey50", size = base_size,
                                   margin = margin(b = 6)),
      plot.caption  = element_text(color = "grey60", size = 8,
                                   hjust = 1, margin = margin(t = 5)),
      axis.title    = element_text(size = base_size, color = "grey40"),
      axis.text     = element_text(size = base_size - 1),
      panel.grid.minor   = element_blank(),
      panel.grid.major.y = element_line(color = "grey85", linewidth = 0.3),
      panel.grid.major.x = element_line(color = "grey85", linewidth = 0.3),
      legend.title  = element_text(size = base_size - 1),
      legend.text   = element_text(size = base_size - 2),
      strip.text    = element_text(face = "bold", size = base_size)
    )
}
theme_set(theme_pres())

SOURCE_CAPTION <- "Source: ACS 5-Year Estimates · TidyTuesday 2025"

EXCLUDE_TERRITORIES <- c("Puerto Rico", "United States Virgin Islands",
                         "Guam", "Commonwealth of the Northern Mariana Islands",
                         "American Samoa")

clean_water <- function(df) {
  df |>
    mutate(
      rate   = percent_lacking_plumbing / 100,
      state  = str_extract(name, "(?<=, ).+$"),
      county = str_remove(name, ",.*$")
    ) |>
    filter(!is.na(rate), !is.na(total_pop), total_pop > 0,
           !state %in% EXCLUDE_TERRITORIES)
}

tuesdata         <- tt_load(2025, week = 4)
water_2023_clean <- clean_water(tuesdata$water_insecurity_2023)
water_2022_clean <- clean_water(tuesdata$water_insecurity_2022)

nat_avg <- mean(water_2023_clean$rate, na.rm = TRUE)
nat_med <- median(water_2023_clean$rate, na.rm = TRUE)

top_counties <- water_2023_clean |>
  arrange(desc(rate)) |> slice_head(n = 10) |>
  select(county, state, total_pop, plumbing, rate)

state_summary <- water_2023_clean |>
  group_by(state) |>
  summarise(
    n_counties    = n(),
    total_pop     = sum(total_pop,  na.rm = TRUE),
    total_lacking = sum(plumbing,   na.rm = TRUE),
    weighted_rate = total_lacking / total_pop,
    .groups = "drop"
  ) |>
  arrange(desc(weighted_rate))

water_2023_clean <- water_2023_clean |> mutate(log_pop = log10(total_pop))
fit           <- lm(rate ~ log_pop, data = water_2023_clean)
intercept_val <- round(coef(fit)[], 4)[1]
slope_val     <- round(coef(fit)[], 4)[2]
r2_val        <- round(summary(fit)$r.squared, 3)

water_change <- water_2022_clean |>
  select(geoid, rate_2022 = rate) |>
  inner_join(
    water_2023_clean |> select(geoid, county, state,
                               rate_2023 = rate, total_pop),
    by = "geoid"
  ) |>
  mutate(change    = rate_2023 - rate_2022,
         direction = if_else(change > 0, "Worsened", "Improved"))
```

