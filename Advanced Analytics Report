-- Advanced Analytical Reports --

--- 1
SELECT
    start_station_id AS station_id,
    COUNT(*) AS rides_started
FROM ride
GROUP BY start_station_id
ORDER BY rides_started DESC
LIMIT 5;


---2
SELECT
    DATE_TRUNC('month', p.paid_at) AS month,
    COALESCE(sp.plan_type, 'pay_as_you_go') AS membership_type,
    SUM(p.amount) AS total_revenue
FROM payment p
LEFT JOIN subscription_plan sp 
       ON p.plan_id = sp.plan_id
GROUP BY month, membership_type
ORDER BY month, membership_type;

---3
SELECT
    b.bike_id,
    b.battery_level,
    b.station_id,
    b.dock_id
FROM bike b
JOIN dock d ON b.dock_id = d.dock_id
WHERE b.type = 'ELECTRIC'
  AND b.battery_level < 20
  AND b.dock_id IS NOT NULL;

---4 
WITH user_dist AS (
    SELECT 
        user_id,
        SUM(distance_km) AS total_distance
    FROM ride
    WHERE distance_km IS NOT NULL
    GROUP BY user_id
),
avg_dist AS (
    SELECT AVG(total_distance) AS avg_distance
    FROM user_dist
)
SELECT 
    u.user_id,
    u.total_distance
FROM user_dist u, avg_dist a
WHERE u.total_distance > a.avg_distance
ORDER BY u.total_distance DESC;


--- Avrage distance ridden --- (not a query)
SELECT AVG(total_distance) AS avg_distance
FROM (
    SELECT user_id, SUM(distance_km) AS total_distance
    FROM ride
    WHERE distance_km IS NOT NULL
    GROUP BY user_id
) AS user_dist;
