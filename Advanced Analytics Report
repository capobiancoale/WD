--- Station Popularity
-- We need to know from which station start most of the rides, then order form the most used station to the least one, and then take the first 5 

SELECT start_station_id AS station_id,
COUNT(*) AS rides_started
FROM ride
GROUP BY start_station_id
ORDER BY rides_started DESC
LIMIT 5;


--- Revenue Analysis 
--- We need to calculate the total for month and plan

select DATE_TRUNC('month', paid_at) as month, -- to aggregate payments by month
plan_id,
sum(amount) as total_revenue
from payment
group by month, plan_id
order by month;


--- Manteinance Alert
--- We need to use JOIN, take oinly electri bikes with battery < 20%, which are currently docked  

SELECT b.bike_id, b.battery_level, b.station_id, b.dock_id
FROM bike b
JOIN dock d ON b.dock_id = d.dock_id
WHERE b.type = 'ELECTRIC'
AND b.battery_level < 20
AND b.dock_id IS NOT NULL;


--- User Behavior 
--- We need to find clients who have ridden more than average distance, sorted by ridden distance
---> We calculate the total distance ridden by each client, then compute the average. Then keep clients who are above average and order them by distance ridden 

select user_id, sum(distance_km) as total_distance
from ride
where distance_km is not null
group by user_id
having sum(distance_km) > (
  select avg(total_dist) 
  from (
  select sum(distance_km) as total_dist
  from ride where distance_km is not null
  group by user_id) 
  as sub)
order by total_distance desc;


